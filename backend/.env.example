# Copy to .env and adjust as needed. All variables are prefixed CLIPCOACH_
# (see app/core/config.py).

CLIPCOACH_ENVIRONMENT=development
CLIPCOACH_DEBUG=true
CLIPCOACH_CORS_ORIGINS=http://localhost:3000

# Production example (comma-separated):
# CLIPCOACH_CORS_ORIGINS=https://your-app.vercel.app,http://localhost:3000

# Hosted render safety (Railway/low-RAM): cap output height
# CLIPCOACH_MAX_RENDER_HEIGHT=480

# Highlight-detection algorithm tuning (PRD 6.3) — safe to leave as defaults.
# CLIPCOACH_TARGET_DURATION_SECONDS=90
# CLIPCOACH_AUDIO_WEIGHT=0.6
# CLIPCOACH_MOTION_WEIGHT=0.4
# CLIPCOACH_MIN_GAP_BETWEEN_CLIPS_SECONDS=8
# CLIPCOACH_MOTION_SAMPLE_FPS=2
