# Copy to .env.local for local development.
# Points the frontend at your local FastAPI backend (uvicorn app.main:app --reload --port 8000).
NEXT_PUBLIC_API_URL=http://localhost:8000

# When deployed on Vercel, set this in the Vercel project's environment variables
# to your hosted backend URL (e.g. Railway), since the ffmpeg media pipeline
# is not suited to Vercel's serverless runtime.
